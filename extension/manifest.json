{
  "manifest_version": 3,
  "name": "PhishGuard (Student Project)",
  "version": "1.0",
  "permissions": ["tabs","scripting","storage","activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_start"
    }
  ]
}
